cd web

# Format-check only staged files (skip deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | sed 's|^web/||')
if [ -n "$STAGED_FILES" ]; then
  echo "$STAGED_FILES" | xargs bun biome format --no-errors-on-unmatched
fi

bun run typecheck && bun run test
